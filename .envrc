#!/usr/bin/env bash

if ! python3 -c "import venv"; then

read -r -p "Python venv is needed would you like to try to auto install it? [Y/n]" response

case "$response" in
    [nN][oO]|[nN]) 
        printf "Please install python venv\nTry \`sudo apt install python3-venv\`\n"
        exit 1;
        ;;
    *)
        sudo apt install python3-venv
        ;;
esac

fi

if ! [ -d "./.env/" ]; then
    python3 -m venv .venv
fi



source ./.venv/bin/activate

